## ── 테스트 환경 변수 ─────────────────────────────────────────────
## docker-compose.test.yml 에서 참조
## .gitignore 에 포함되어 있어야 함

# GHCR 인증
GHCR_TOKEN=
GITHUB_USER=

# ************
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=

MAIL_FROM=
ALERT_EMAIL=

# AI 분석
GEMINI_API_KEY=
ANTHROPIC_API_KEY=


# Multi-node Docker API
DOCKER_MONITOR_NODES_NODES_0_NAME=
DOCKER_MONITOR_NODES_NODES_0_HOST=
DOCKER_MONITOR_NODES_NODES_0_PORT=2375
DOCKER_MONITOR_NODES_NODES_0_CONNECTION_TYPE=

DOCKER_MONITOR_NODES_NODES_1_NAME=
DOCKER_MONITOR_NODES_NODES_1_HOST=
DOCKER_MONITOR_NODES_NODES_1_PORT=
DOCKER_MONITOR_NODES_NODES_1_CONNECTION_TYPE=

DOCKER_MONITOR_NODES_NODES_2_NAME=
DOCKER_MONITOR_NODES_NODES_2_HOST=
DOCKER_MONITOR_NODES_NODES_2_PORT=
DOCKER_MONITOR_NODES_NODES_2_CONNECTION_TYPE=

# ── Proxy (CP 점프 호스트) ────────────────────────────────────────
DOCKER_MONITOR_NODES_PROXY_HOST=
DOCKER_MONITOR_NODES_PROXY_PORT=
DOCKER_MONITOR_NODES_PROXY_USER=
DOCKER_MONITOR_NODES_PROXY_KEY_PATH=
# ── Multi Logs 프리셋 ─────────────────────────────────────────────
# JSON 배열로 선언. 비워두면 application.yml의 presets 사용
MULTI_LOGS_PRESETS=[{"name":"exercise-auth","panels":1,"containers":["exercise-auth"]},{"name":"전체 스택","panels":4,"containers":["exercise-auth","schedule-diary","kite","docker-monitor-postgres"]}]
